<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/ListOfNotesFragment">

    <fragment
        android:id="@+id/ListOfNotesFragment"
        android:name="com.example.notesapp.ui.main.ListOfNotesFragment"
        android:label="@string/list_of_notes_fragment_label"
        tools:layout="@layout/fragment_list_of_notes_list">

        <action
            android:id="@+id/action_ListOfNotesFragment_to_SecondFragment"
            app:destination="@id/SecondFragment" />
    </fragment>
    <fragment
        android:id="@+id/SecondFragment"
        android:name="com.example.notesapp.SecondFragment"
        android:label="@string/second_fragment_label"
        tools:layout="@layout/fragment_second">

        <action
            android:id="@+id/action_SecondFragment_to_ListOfNotesFragment"
            app:destination="@id/ListOfNotesFragment" />
    </fragment>
</navigation>